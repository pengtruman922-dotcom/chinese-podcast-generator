# 环境变量配置示例
# 复制此文件为 .env 并填写您的密钥

# ASR配置 (火山引擎)
VOLC_ASR_APPID=yourid
VOLC_ASR_TOKEN=yourtoken

# 翻译配置 (阿里灵积)
DASHSCOPE_API_KEY=yourtoken

# TTS配置 (火山引擎)
VOLC_TTS_APPID=yourid
VOLC_TTS_TOKEN=yourtoken

# TOS对象存储配置 (火山引擎)
VOLC_TOS_ACCESS_KEY=your_tos_access_key_here
VOLC_TOS_SECRET_KEY=your_tos_secret_key_here
